# Desactivar Oh My Posh (o cualquier cosa externa)
unset PROMPT_COMMAND

# Pequeña función para mostrar la rama de Git
parse_git_branch() {
     git branch 2> /dev/null | sed -e '/^[^*]/d' -e 's/* \(.*\)/(\1) /'
}

# PS1: Tu prompt minimalista de siempre (esperando comandos)
export PS1='\[\033[01;32m\]\u\[\033[00m\] \[\033[01;34m\]\w\[\033[00m\] \[\033[01;33m\]$(parse_git_branch)\[\033[00m\]❯ '

# PS0: El "fantasma" que aparece solo al presionar Enter
# Sube 1 línea (\e[1A), va a la columna derecha (\e[...G), imprime la hora (\t) en gris oscuro (\e[90m) y regresa (\e[u)
export PS0='\e[s\e[1A\e[$((${COLUMNS:-80}-8))G\e[90m\t\e[0m\e[u'

# -----------------------------------------------------
# Autocompletado Inteligente (Presiona TAB)
# -----------------------------------------------------
# Ignorar mayúsculas y minúsculas (downlo -> Downloads)
bind 'set completion-ignore-case on'

# Mostrar todas las opciones si hay varias (sin doble Tab)
bind 'set show-all-if-ambiguous on'

# Hacer que TAB navegue por las opciones directamente
bind '"\t": menu-complete'

# Shift+TAB para retroceder en las opciones
bind '"\e[Z": menu-complete-backward'
